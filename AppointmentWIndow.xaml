<Window x:Class="exam_2025.AppointmentWIndow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"        
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"      

        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:exam_2025"
        mc:Ignorable="d"
        Title="AppointmentWIndow" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40*"/>
            <ColumnDefinition Width="40*"/>
            <ColumnDefinition Width="20*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="20*"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="40*"/>
            <RowDefinition Height="15*"/>
            <RowDefinition Height="15*"/>
        </Grid.RowDefinitions>

        <DatePicker Grid.Row="0" Grid.Column="0" x:Name="dpAppointmentDate"/>
        <Label Grid.Row="1" Grid.Column="0" Content="Notes"/>
        <TextBox Grid.Row="2" Grid.Column="0" Margin="10" Grid.RowSpan="3" Grid.ColumnSpan="2" x:Name="tbxAppointmentNotes"/>
        <materialDesign:TimePicker Grid.Row="0" Grid.Column="1" x:Name="tpAppointmentTime"/>
        <Button x:Name="btnAdd" Grid.Row="3" Grid.Column="2" Content="Add" Click="btnAdd_Click"/>
        <Button Grid.Row="4" Grid.Column="2" Content="Update" x:Name="btnUpdate" Click="btnUpdate_Click"/>

    </Grid>
</Window>
