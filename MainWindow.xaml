<Window x:Class="exam_2025.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"   
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"      
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:exam_2025"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="40*"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="40*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40*"/>
            <ColumnDefinition Width="40*"/>
            <ColumnDefinition Width="20*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Patients"/>
        <ListBox x:Name="lbxPatients" Grid.Row="1" Grid.Column="0" Margin="10" Grid.RowSpan="3" SelectionChanged="lbxPatients_SelectionChanged"/>
        
        <Label Grid.Row="0" Grid.Column="1" Content="Patient Details"/>

        <Grid Grid.Row="1" Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="tbxFirstName" Grid.Row="0" Grid.Column="0" Margin="5" materialDesign:HintAssist.Hint="First Name"/>
            <TextBox x:Name="tbxSurname" Grid.Row="0" Grid.Column="1" Margin="5"  materialDesign:HintAssist.Hint="Surname"/>
            <TextBox x:Name="tbxContactNumber" Grid.Row="1" Grid.Column="0" Margin="5"  materialDesign:HintAssist.Hint="Contact Number"/>
            <DatePicker x:Name="dpDateOfBirth" Grid.Row="1" Grid.Column="1" Margin="5"/>
            
            
        </Grid>
        
        
        <Button x:Name="btnAddPatient" Grid.Row="1" Grid.Column="2" Content="Add" Margin="10" Click="btnAddPatient_Click"/>


        <Label Grid.Row="2" Grid.Column="1" Content="Appointments"/>

        <ListBox x:Name="lbxAppointments" Grid.Row="3" Grid.Column="1" Margin="10"/>

        <StackPanel Grid.Row="3" Grid.Column="2">
            <Button x:Name="btnAddAppointment" Content="Add" Margin="10" Click="btnAddAppointment_Click"/>
            <Button x:Name="btnEditAppointment" Content="Edit" Margin="10" Click="btnEditAppointment_Click"/>
        </StackPanel>
        
        
       

    </Grid>
</Window>
